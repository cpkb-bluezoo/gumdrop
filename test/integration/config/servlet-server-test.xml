<?xml version='1.0' standalone='yes'?>
<!--
  Servlet container integration test configuration.
  
  This configuration sets up a ServletService with a test web application
  for integration testing.
-->
<gumdrop>
    <!-- Servlet container -->
    <service id="testServlet" class="org.bluezoo.gumdrop.servlet.ServletService">
        <property name="bufferSize">8192</property>

        <!-- Test web application context (root resolved relative to this file) -->
        <context path="" root="../webapp" distributable="false"/>

        <!-- TCP listener -->
        <listener class="org.bluezoo.gumdrop.http.HTTPListener">
            <property name="port">19080</property>
            <property name="addresses">127.0.0.1</property>
        </listener>
    </service>
</gumdrop>
